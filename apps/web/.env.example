# ===========================================
# apps/web - Next.js environment variables
# ===========================================
# Copy to .env.local in this directory and fill in real values.

# Public app metadata
NEXT_PUBLIC_APP_NAME="IncidentMind"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database (Prisma reads DATABASE_URL from here or the repo root .env)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/incidentmind?schema=public"
