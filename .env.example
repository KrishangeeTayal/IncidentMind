# ===========================================
# IncidentMind - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Each app also has its own .env.example with app-specific values.

# ===========================================
# General
# ===========================================
NODE_ENV=development

# ===========================================
# Database (PostgreSQL)
# ===========================================
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/incidentmind?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/incidentmind?schema=public"

# ===========================================
# Web App (apps/web - Next.js)
# ===========================================
NEXT_PUBLIC_APP_NAME="IncidentMind"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# Mastra (apps/mastra)
# ===========================================
MASTRA_PORT=4111
MASTRA_API_URL="http://localhost:4111"

# LLM Provider Keys (used by Mastra agents)
# Add whichever providers you plan to use.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# ===========================================
# Future Integrations (placeholders - NOT USED YET)
# ===========================================
# Qdrant
QDRANT_URL=""
QDRANT_API_KEY=""
QDRANT_COLLECTION_INCIDENTS=""
QDRANT_COLLECTION_RUNBOOKS=""

# Enkrypt AI
ENKRYPT_API_KEY=""
ENKRYPT_API_URL=""
ENKRYPT_GUARDRAIL_ID=""
ENKRYPT_DETECTOR_ID=""
