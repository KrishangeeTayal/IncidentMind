{
  "name": "incidentmind",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered Incident Response platform that helps engineers reduce MTTR.",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @incidentmind/web dev",
    "dev:mastra": "pnpm --filter @incidentmind/mastra dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @incidentmind/web build",
    "build:mastra": "pnpm --filter @incidentmind/mastra build",
    "start": "pnpm -r --parallel run start",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm -r exec rm -rf node_modules .next dist .turbo && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=8.15.0"
  },
  "packageManager": "pnpm@8.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
